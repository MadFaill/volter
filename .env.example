# Скопируйте в .env и заполните. Реальный .env в git не коммитится.

# Внешний порт reverse-proxy (nginx).
VOLTER_HTTP_PORT=80

# Секрет подписи сессий. Если пусто — backend сгенерирует и сохранит в ./data/jwt.secret.
VOLTER_JWT_SECRET=

# Фаза 1: пути к домашним каталогам уже авторизованных CLI-агентов (для будущих шагов).
CODEX_HOME_HOST=/home/volt/.codex
CLAUDE_HOME_HOST=/home/volt/.claude
